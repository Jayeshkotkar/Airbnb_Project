<% layout("/layouts/boilerplate") %>

    <head>
        <link rel="stylesheet" href="/css/new.css">
    </head>

    <body>
        <div class="form-wrapper">
            <h1 class="form-title">Create a New Listing</h1>
            <form action="/listing" method="post" enctype="multipart/form-data" class="listing-form needs-validation"
                novalidate>
                <div class="form-field">
                    <label for="title">Title:</label>
                    <input type="text" name="listing[title]" placeholder="Title" class="form-input form-control"
                        required>
                </div>

                <div class="form-field">
                    <label for="description">Description:</label>
                    <input type="text" name="listing[description]" placeholder="Description"
                        class="form-input form-control" required>
                </div>

                <div class="form-field">
                    <label for="image">Upload Listing Image</label>
                    <input type="file" name="listing[image]" class="form-input form-control">
                </div>

                <div class="form-field-container">
                    <div class="form-field">
                        <label for="price">Price:</label>
                        <input type="text" name="listing[price]" placeholder="Price" class="form-input form-control"
                            required>
                    </div>

                    <div class="form-field">
                        <label for="location">Location:</label>
                        <input type="text" name="listing[location]" placeholder="Location"
                            class="form-input form-control" required>
                    </div>
                </div>

                <div class="form-field">
                    <label for="country">Country:</label>
                    <input type="text" name="listing[country]" placeholder="Country" class="form-input form-control"
                        required>
                </div>

                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </body>